{
  "version": "1.0.0",
  "connectors": [
    {
      "name": "claude-desktop",
      "display_name": "Claude Desktop",
      "detection": {
        "method": "mcp_config",
        "platform_paths": {
          "windows": ["%APPDATA%\\Claude\\claude_desktop_config.json"],
          "darwin":  ["~/Library/Application Support/Claude/claude_desktop_config.json"],
          "linux":   ["~/.config/Claude/claude_desktop_config.json"]
        },
        "config_format": "json"
      },
      "mcp_config_template": {
        "key_path": "mcpServers.nexus",
        "value": {"command": "nexus", "args": ["mcp-stdio"]}
      },
      "health_check": {
        "type": "filesystem",
        "platform_paths": {
          "windows": ["%APPDATA%\\Claude\\claude_desktop_config.json"],
          "darwin":  ["~/Library/Application Support/Claude/claude_desktop_config.json"],
          "linux":   ["~/.config/Claude/claude_desktop_config.json"]
        }
      },
      "known_issues": [
        {
          "id": "missing_mcp_servers_key",
          "description": "mcpServers key absent from config",
          "fix_recipe": [
            {"action": "backup_file",     "params": {"path": "{{config_path}}"}},
            {"action": "set_config_key",  "params": {"path": "{{config_path}}", "key": "mcpServers.nexus.command", "value": "nexus"}},
            {"action": "set_config_key",  "params": {"path": "{{config_path}}", "key": "mcpServers.nexus.args",    "value": ["mcp-stdio"]}},
            {"action": "verify_config",   "params": {"path": "{{config_path}}"}}
          ]
        },
        {
          "id": "wrong_nexus_command",
          "description": "nexus command path points to wrong binary",
          "fix_recipe": [
            {"action": "backup_file",     "params": {"path": "{{config_path}}"}},
            {"action": "set_config_key",  "params": {"path": "{{config_path}}", "key": "mcpServers.nexus.command", "value": "nexus"}},
            {"action": "verify_config",   "params": {"path": "{{config_path}}"}}
          ]
        }
      ]
    },
